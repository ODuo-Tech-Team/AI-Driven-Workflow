# AI-Driven Workflow — variáveis de ambiente
# Copie pra .env e preencha. NÃO commite .env.

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
APP_ENV=dev                         # dev | staging | prod
APP_LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
APP_HOST=0.0.0.0
APP_PORT=8000

# -----------------------------------------------------------------------------
# Redis (queue)
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Claude (Anthropic)
# -----------------------------------------------------------------------------
# Usado pelo Claude Agent SDK (Python)
ANTHROPIC_API_KEY=sk-ant-...
# Hard cap por job em USD — protege contra loop infinito
CLAUDE_BUDGET_USD_PER_JOB=2.0

# -----------------------------------------------------------------------------
# Linear
# -----------------------------------------------------------------------------
LINEAR_API_KEY=lin_api_...
LINEAR_WEBHOOK_SECRET=replace-me
LINEAR_TEAM_ID=

# -----------------------------------------------------------------------------
# GitHub
# -----------------------------------------------------------------------------
GITHUB_TOKEN=ghp_...
GITHUB_WEBHOOK_SECRET=replace-me
GITHUB_REPO_OWNER=ODuo-Tech-Team
GITHUB_REPO_NAME=

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
OTEL_SERVICE_NAME=ai-workflow
OTEL_EXPORTER_OTLP_ENDPOINT=
